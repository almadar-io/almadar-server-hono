{
  "name": "@almadar/server-hono",
  "version": "0.1.1",
  "description": "Hono server infrastructure for Almadar applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc -p tsconfig.decl.json",
    "build:watch": "tsup --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run --passWithNoTests",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@almadar/core": ">=4.8.2",
    "@almadar/server": ">=2.3.6",
    "hono": "^4.7.0"
  },
  "peerDependencies": {
    "@hono/zod-validator": ">=0.4.0",
    "@almadar-io/agent": ">=5.5.6"
  },
  "peerDependenciesMeta": {
    "@almadar-io/agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@almadar/eslint-plugin": ">=2.3.0",
    "@hono/zod-validator": "^0.4.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/parser": "8.56.0",
    "eslint": "10.0.0",
    "firebase-admin": "^12.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^3.24.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/almadar-io/almadar-server-hono.git"
  },
  "license": "BSL-1.1",
  "keywords": [
    "almadar",
    "server",
    "hono",
    "middleware"
  ]
}
